{
  "name": "winnow",
  "version": "0.1.0",
  "private": true,
  "description": "A Firefox extension that winnows your YouTube feed down to what you actually want to watch.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=nonlive",
    "test:e2e:live": "playwright test --project=live",
    "test:e2e:ext": "npm run zip && node --test e2e/extension/*.test.mjs",
    "zip": "npm run build && node scripts/zip.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.1.1",
    "selenium-webdriver": "^4.46.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}

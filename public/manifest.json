{
  "manifest_version": 3,
  "name": "Winnow",
  "version": "0.1.0",
  "description": "Winnow your YouTube feed down to what you actually want to watch. AI-curated, calm, no engagement bait.",
  "browser_specific_settings": {
    "gecko": {
      "id": "winnow@misuse.org",
      "strict_min_version": "121.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Open Winnow",
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  },
  "permissions": ["storage", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.youtube-nocookie.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "embed_referer", "enabled": true, "path": "dnr-rules.json" }
    ]
  }
}
